# ─── DATABASE ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://animface:animface123@localhost:5432/animface_db
SYNC_DATABASE_URL=postgresql://animface:animface123@localhost:5432/animface_db

# ─── SECURITY ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── REDIS (Celery broker) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── STORAGE ──────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
MAX_VIDEO_SIZE_MB=100
MAX_VIDEO_DURATION_SECONDS=60

# ─── AWS (for later cloud migration) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=animface-videos
AWS_REGION=us-east-1

# ─── APP ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DEBUG=true

# ─── ANIME AI PIPELINE ────────────────────────────────
ANIME_MODEL=mock
ANIME_WORKER_CONCURRENCY=2
